###################################################
# PKG_CXXFLAGS = -O3  
# CXX_STD = c++03
# CXX98STD = -std=c++98
# CXXFLAGS += "-fpermissive -std=c++98"

ifeq "$(MECAB_LIBS)" ""
    MECAB_LIBS = $(shell "$(R_HOME)/bin$(R_ARCH_BIN)/Rscript.exe" -e "cat(stringr::str_sub(stringr::str_replace_all(system('mecab-config.bat --libs-only-L', intern = T), stringr::fixed('\\'), '/'), 1, nchar(libs)-1))")
endif

PKG_LIBS = -L$(MECAB_LIBS) -lmecab

PKG_CPPFLAGS = -I.

